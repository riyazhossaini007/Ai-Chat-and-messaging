# Core
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plaxeai
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=7d

# Audit
AUDIT_SIGNING_SECRET=replace-with-strong-random-secret

# Message encryption at rest
MESSAGE_KEK_B64=replace-with-base64-32-byte-key
MESSAGE_KEK_ID=primary-v1
MESSAGE_KEK_MAP_JSON=

# Health
HEALTH_TOKEN=replace-with-strong-random-token

# Transport hardening
ENFORCE_HTTPS=0
HTTPS_REDIRECT_CODE=308
TRUST_PROXY=1

# Security profile
SECURITY_STRICT_MODE=0
SECURITY_STARTUP_DIAGNOSTICS=1
